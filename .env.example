# Copy to .env for local development. NEVER commit .env.
# On Azure App Service, set these as Application Settings instead.

# ─── Required ────────────────────────────────────────────────────────────────

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── Optional (with sensible defaults) ───────────────────────────────────────

# Where the patient profile and jobs JSON live.
# Production (Azure App Service): /home/data
# Local dev: ./data
DATA_DIR=./data

# Model selection (override per-environment if needed)
# See agent/config.py for the canonical defaults.
# Tiering (from the Fable 5 prompt audit): the reasoning-heavy agents run on
# Opus 4.8; the constraint-following / deterministic ones stay on Sonnet 5.
ANTHROPIC_MODEL_INTAKE=claude-opus-4-8
ANTHROPIC_MODEL_ORCHESTRATOR=claude-opus-4-8
ANTHROPIC_MODEL_EXEC_SUMMARY=claude-opus-4-8
ANTHROPIC_MODEL_QUESTIONS=claude-sonnet-5
ANTHROPIC_MODEL_CHAT=claude-opus-4-8
# classify has no override here — it inherits ANTHROPIC_MODEL (claude-sonnet-5),
# which the audit recommended keeping for this deterministic normalisation task.

# Ensemble deep-sweep (on-demand pre-appointment research pass). Comma-separated
# model IDs run in parallel with relaxed suppression; the synthesis model unions
# their reports. Read-only — never writes findings back to the profile.
ANTHROPIC_DEEPSWEEP_MODELS=claude-fable-5,claude-opus-4-8
ANTHROPIC_DEEPSWEEP_SYNTHESIS=claude-opus-4-8

# Dual-pass intake verification (P1). OFF by default. When set, a second,
# quote-anchored extraction pass adds only source-verifiable missed items.
# Enable once scripts/eval_harness.py shows a recall lift on a golden set.
INTAKE_VERIFY=0

# Server
PORT=8000
LOG_LEVEL=INFO

# Backups
BACKUP_RETENTION_DAYS=30
