# Auto-detect text files
* text=auto eol=lf

# Force LF for files that run on Linux (Azure App Service)
*.sh         text eol=lf
*.py         text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.toml       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
.env*        text eol=lf
Dockerfile   text eol=lf

# Windows-only files
*.ps1        text eol=crlf
*.cmd        text eol=crlf
*.bat        text eol=crlf

# Binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.pdf        binary
*.docx       binary
*.xlsx       binary
*.pptx       binary
*.ico        binary
